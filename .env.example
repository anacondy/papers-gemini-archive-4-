# Environment Configuration Template
# Last Updated: 2026-07-06 (Trevor Reznik Audit Phase 1)

# ------------------------------------------------------------------------------
# SECURITY WARNING: 
# Never commit the .env file to version control. 
# Use this .env.example as a template.
# ------------------------------------------------------------------------------

# Flask Configuration
FLASK_ENV=production
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-secret-generated-by-secrets-module
DEBUG=False

# Admin Authentication
# Generate a strong password. Do not use common words.
ADMIN_PASSWORD=replace-with-a-strong-random-password

# Upload Configuration
# 16MB Limit enforced in app.py
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads

# Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_STORAGE_URL=memory://
